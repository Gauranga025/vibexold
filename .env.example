# Database connection string for MongoDB
DATABASE_URL=mongodb://localhost:27017/vibe-editor

# NextAuth.js secret for session encryption (generate with: openssl rand -base64 32)
AUTH_SECRET=your_auth_secret_here

# GitHub OAuth credentials (from https://github.com/settings/developers)
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# Google OAuth credentials (from https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# Google Gemini API Key for AI features (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
